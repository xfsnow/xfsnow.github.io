	<labelMode val="0"/>
	<startPoint  x="0.31999999999999895" y="0.559999999999998" z="1"/>
</element>
<expression label="color1" exp="&quot;ff0000&quot;"/>
<element type="text" label="color1">
	<symbolic val="true" />
	<show object="false" label="false"/>
	<objColor r="0" g="0" b="0" alpha="0"/>
	<layer val="0"/>
	<labelMode val="0"/>
	<startPoint  x="0.31999999999999895" y="0.559999999999998" z="1"/>
</element>
<element type="numeric" label="n">
	<value val="10"/>
	<symbolic val="true" />
	<show object="true" label="true"/>
	<objColor r="0" g="0" b="255" alpha="0.1"/>
	<layer val="0"/>
	<labelMode val="1"/>
	<animation step="1" speed="1" type="0" playing="false"/>
</element>
<element type="numeric" label="m">
	<value val="-1"/>
