	<show object="true" label="true"/>
	<objColor r="255" g="0" b="0" alpha="0.1"/>
	<layer val="0"/>
	<labelMode val="1"/>
	<animation step="1" speed="1" type="0" playing="false"/>
</element>
<command name="GCD">
	<input a0="m" a1="n"/>
	<output a0="d"/>
</command>
<element type="numeric" label="d">
	<value val="1"/>
	<symbolic val="true" />
	<objColor r="0" g="0" b="0" alpha="0.1"/>
</element>
<expression label="q" exp="n / d" />
<element type="numeric" label="q">
	<value val="10"/>
	<symbolic val="true" />
	<objColor r="0" g="0" b="0" alpha="0.1"/>
</element>
<expression label="p" exp="m / d" />
<element type="numeric" label="p">
	<value val="-1"/>
	<symbolic val="true" />
	<objColor r="0" g="0" b="0" alpha="0.1"/>
</element>
<expression label="latex" exp="&quot;&quot; + (LaTeX[If[(¬Defined[m / n]) ∨ abs(m / n) ≟ Infinity, &quot;?&quot;, If[showPlusSign ∧ (m / n &gt; 0), &quot;+&quot;, &quot;&quot;] + (If[abs(q) ≟ 1, &quot;\fgcolor{&quot; + color1 + &quot;}{&quot; + ((p * q)) + &quot;}&quot;, If[m / n  &lt;  0, &quot;-&quot;, &quot;&quot;] + &quot;\frac{\fgcolor{&quot; + color1 + &quot;}{&quot; + (abs(p)) + &quot;}}{\fgcolor{&quot; + color2 + &quot;}{&quot; + (abs(q)) + &quot;}}&quot;])]]) + &quot;&quot;" />
<element type="text" label="latex">
	<show object="true" label="true" ev="8"/>
	<objColor r="0" g="0" b="0" alpha="0"/>
	<layer val="0"/>
	<labelMode val="0"/>
	<isLaTeX val="true"/>
	<font serif="false" sizeM="1" size="0" style="0"/>
	<startPoint  x="0" y="0" z="1"/>
</element>
</construction>
</macro>
