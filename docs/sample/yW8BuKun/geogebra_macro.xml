<?xml version="1.0" encoding="utf-8"?>
<geogebra format="5.0" version="5.0.284.0"  xsi:noNamespaceSchemaLocation="http://www.geogebra.org/ggt.xsd" xmlns="" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" >
<macro cmdName="BezierPath" toolName="BezierPath" toolHelp="BezierPath[ {&lt;points&gt;}, &lt;slider&gt;]" iconFile="" showInToolBar="true" copyCaptions="true" viewId="1">
<macroInput a0="pts" a1="t"/>
<macroOutput a0="loc1"/>
<construction title="" author="" date="">
<expression label ="pts" exp="{(1, 0), (0, 0), (1, 1), (0, 1)}"/>
<element type="list" label="pts">
	<show object="true" label="false" ev="4"/>
	<objColor r="0" g="100" b="0" alpha="0"/>
	<bgColor r="255" g="255" b="255" alpha="255"/>
	<layer val="0"/>
	<labelMode val="0"/>
	<animation step="1" speed="1" type="0" playing="false"/>
	<lineStyle thickness="2" type="0" typeHidden="1"/>
	<pointSize val="5"/>
	<pointStyle val="0"/>
</element>
<command name="Length">
	<input a0="pts"/>
	<output a0="n"/>
</command>
<element type="numeric" label="n">
	<value val="4"/>
	<objColor r="0" g="0" b="0" alpha="0.1"/>
</element>
<element type="numeric" label="t">
	<value val="0.3"/>
	<show object="true" label="true"/>
	<objColor r="0" g="0" b="0" alpha="0.1"/>
	<layer val="0"/>
	<labelMode val="1"/>
	<animation step="0.05" speed="1" type="0" playing="false"/>
</element>
<expression label="s" exp="1 - t" />
<element type="numeric" label="s">
	<value val="0.7"/>
	<objColor r="0" g="0" b="0" alpha="0.1"/>
</element>
<command name="Sequence">
	<input a0="(s^(n - 1 - k) * t^(k))" a1="k" a2="0" a3="n - 1"/>
	<output a0="terms"/>
</command>
<element type="list" label="terms">
	<objColor r="0" g="100" b="0" alpha="0.1"/>
	<bgColor r="255" g="255" b="255" alpha="255"/>
	<lineStyle thickness="2" type="0" typeHidden="1"/>
	<pointSize val="5"/>
	<pointStyle val="0"/>
</element>
<command name="Sequence">
	<input a0="Binomial[n - 1, k]" a1="k" a2="0" a3="n - 1"/>
	<output a0="coefs"/>
</command>
<element type="list" label="coefs">
	<objColor r="0" g="100" b="0" alpha="0.1"/>
	<bgColor r="255" g="255" b="255" alpha="255"/>
	<lineStyle thickness="2" type="0" typeHidden="1"/>
	<pointSize val="5"/>
	<pointStyle val="0"/>
</element>
<command name="Sum">
	<input a0="Zip[((c * t) * P), c, coefs, t, terms, P, pts]"/>
	<output a0="A"/>
</command>
<element type="point" label="A">
	<show object="true" label="false" ev="4"/>
	<objColor r="0" g="0" b="255" alpha="0"/>
	<layer val="0"/>
	<labelMode val="0"/>
	<coords x="0.5319999999999999" y="0.216" z="1"/>
	<pointSize val="3"/>
	<pointStyle val="0"/>
</element>
<element type="locus" label="loc1">
	<show object="true" label="false" ev="4"/>
	<objColor r="0" g="0" b="0" alpha="0"/>
	<layer val="0"/>
	<labelMode val="0"/>
	<animation step="1" speed="1" type="0" playing="false"/>
	<auxiliary val="false"/>
	<lineStyle thickness="2" type="0" typeHidden="1"/>
</element>
</construction>
</macro>
<macro cmdName="Bezier" toolName="Bezier" toolHelp="Bezier[ {&lt;points&gt;} ]" iconFile="" showInToolBar="true" copyCaptions="true" viewId="1">
<macroInput a0="pts"/>
<macroOutput a0="a"/>
<construction title="" author="" date="">
<expression label ="pts" exp="{(0, 0), (1, 1), (0, 2)}"/>
<element type="list" label="pts">
	<show object="true" label="false" ev="4"/>
	<objColor r="0" g="100" b="0" alpha="0"/>
	<bgColor r="255" g="255" b="255" alpha="255"/>
	<layer val="0"/>
	<labelMode val="0"/>
	<animation step="1" speed="1" type="0" playing="false"/>
	<lineStyle thickness="2" type="0" typeHidden="1"/>
	<pointSize val="5"/>
	<pointStyle val="0"/>
</element>
<command name="Length">
	<input a0="pts"/>
	<output a0="n"/>
</command>
<element type="numeric" label="n">
	<value val="3"/>
	<objColor r="0" g="0" b="0" alpha="0.1"/>
</element>
<command name="Sequence">
	<input a0="((Binomial[n - 1, k] * (1 - x)^(n - 1 - k)) * x^(k))" a1="k" a2="0" a3="n - 1"/>
	<output a0="xterms"/>
</command>
<element type="list" label="xterms">
	<show object="false" label="false" ev="4"/>
	<objColor r="0" g="100" b="0" alpha="0"/>
	<bgColor r="255" g="255" b="255" alpha="255"/>
	<layer val="0"/>
	<labelMode val="0"/>
	<lineStyle thickness="2" type="0" typeHidden="1"/>
	<pointSize val="5"/>
	<pointStyle val="0"/>
</element>
<command name="Sum">
	<input a0="Zip[(x(P) * term), P, pts, term, xterms]"/>
	<output a0="fx"/>
</command>
<element type="function" label="fx">
	<show object="false" label="false" ev="4"/>
	<objColor r="153" g="51" b="0" alpha="0"/>
	<layer val="0"/>
	<labelMode val="0"/>
	<lineStyle thickness="3" type="0" typeHidden="1"/>
</element>
<command name="Sum">
	<input a0="Zip[(y(P) * term), P, pts, term, xterms]"/>
	<output a0="fy"/>
</command>
<element type="function" label="fy">
	<show object="false" label="false" ev="4"/>
	<objColor r="0" g="100" b="0" alpha="0"/>
	<layer val="0"/>
	<labelMode val="0"/>
	<lineStyle thickness="3" type="0" typeHidden="1"/>
</element>
<command name="CurveCartesian">
	<input a0="fx(t)" a1="fy(t)" a2="t" a3="0" a4="1"/>
	<output a0="a"/>
</command>
<element type="curvecartesian" label="a">
	<show object="true" label="false" ev="4"/>
	<objColor r="0" g="0" b="0" alpha="0"/>
	<layer val="0"/>
	<labelMode val="0"/>
	<lineStyle thickness="2" type="0" typeHidden="1"/>
</element>
</construction>
</macro>
</geogebra>