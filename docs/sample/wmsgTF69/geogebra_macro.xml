<macroOutput a0="angText"/>
<construction title="" author="" date="">
<expression label ="a" exp="120°"/>
<element type="angle" label="a">
	<angleStyle val="3"/>
	<value val="2.0943951023931953"/>
	<show object="true" label="true"/>
	<objColor r="0" g="100" b="0" alpha="0.1"/>
