	<labelMode val="1"/>
	<lineStyle thickness="2" type="0" typeHidden="2"/>
	<arcSize val="30"/>
	<animation step="1" speed="1" type="0" playing="false"/>
</element>
<command name="If">
	<input a0="cos(a) ≥ 0" a1="a" a2="a + π"/>
