<?xml version="1.0" encoding="utf-8"?>
<geogebra format="5.0" version="5.0.288.0"  xsi:noNamespaceSchemaLocation="http://www.geogebra.org/ggt.xsd" xmlns="" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" >
<macro cmdName="TextPin" toolName="TextPin" toolHelp="TextPin[參考點, 偏移方向, 文字高度, 空隙, 旋轉後寬度, 後高度]" iconFile="" showInToolBar="true" copyCaptions="true" viewId="1">
<macroInput a0="A" a1="v" a2="tH" a3="txtPad" a4="tWr" a5="tHr"/>
